
#
# wm independent hotkeys
#

# terminal emulator
ctrl + alt + l
	xfce4-terminal

# program launcher
#super + @space

# open app using rofi
super + r
	rofi -show run

# switch open window using rofi
alt + Tab
	rofi -show window
super + n
	thunar

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# lock the screen
super + l
	slock

