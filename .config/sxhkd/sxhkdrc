
#
# wm independent hotkeys
#

# terminal emulator
ctrl + alt + l
	xfce4-terminal

# program launcher
#super + @space

# open app using rofi
super + r
	rofi -show run

# switch open window using rofi
alt + Tab
	rofi -show window
super + n
	thunar

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# lock the screen
super + l
	slock

# volume control
XF86AudioLowerVolume
	volumeControl.sh down
XF86AudioRaiseVolume
	volumeControl.sh up
XF86AudioMute
	volumeControl.sh mute

# brightness control
XF86MonBrightnessDown
	brightnessControl.sh down
XF86MonBrightnessUp
	brightnessControl.sh up


